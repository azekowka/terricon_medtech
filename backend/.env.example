# Database. Defaults to a local SQLite file so the app runs with zero infra.
# For PostgreSQL (docker-compose uses this):
# DATABASE_URL=postgresql+psycopg2://medservice:medservice@db:5432/medservice
DATABASE_URL=sqlite:///./medservice.db

# Comma-separated CORS origins, or * for any.
CORS_ORIGINS=*

# Absolute path to the data/ directory (dictionary + clinics). Auto-detected if unset.
# DATA_DIR=/app/data

# USD -> KZT conversion rate used when a source publishes USD prices.
USD_KZT_RATE=470

# Data older than this many days is not shown as "current" (TZ 4).
STALE_DAYS=30

# Raw layer retention for audit, days (TZ 4).
RAW_RETENTION_DAYS=90

# Fuzzy-match threshold (0-100). Below this -> unmatched queue.
MATCH_THRESHOLD=86

# In-process daily reparse scheduler (APScheduler).
ENABLE_SCHEDULER=false
SCHEDULER_CRON_HOUR=3
